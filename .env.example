# Copiez ce fichier vers .env puis renseignez les valeurs. Ne committez JAMAIS .env.

# Token du bot Discord.
# Portail développeur : https://discord.com/developers/applications
#   -> votre application -> Bot -> Reset Token.
# Pensez aussi à activer l'intent « Message Content » (Bot -> Privileged Gateway Intents).
DISCORD_TOKEN=

# Clé de l'API Riot.
# https://developer.riotgames.com/ -> une clé de DÉVELOPPEMENT expire toutes les 24 h.
RIOT_API_KEY=

# Préfixe des commandes (optionnel, défaut « ! »).
COMMAND_PREFIX=!

# Plateforme par défaut (optionnel, défaut « euw1 » ; ex. na1, kr, eun1...).
DEFAULT_PLATFORM=euw1

# Génération des vannes du !classement par une IA (compatible OpenAI, optionnel).
# Sans clé, un générateur local prend le relais.
# Défaut = Groq (gratuit, sans carte bancaire) : créez une clé sur
# https://console.groq.com/keys puis collez-la ci-dessous.
LLM_API_KEY=
# URL et modèle (optionnels). Pour changer de fournisseur, adaptez ces deux valeurs :
#   Groq    : https://api.groq.com/openai/v1                         + llama-3.3-70b-versatile
#   Gemini  : https://generativelanguage.googleapis.com/v1beta/openai + gemini-2.0-flash
#   Mistral : https://api.mistral.ai/v1                              + mistral-small-latest
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
