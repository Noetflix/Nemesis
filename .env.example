# Copiez ce fichier vers .env puis renseignez les valeurs. Ne committez JAMAIS .env.

# Token du bot Discord.
# Portail développeur : https://discord.com/developers/applications
#   -> votre application -> Bot -> Reset Token.
# Pensez aussi à activer l'intent « Message Content » (Bot -> Privileged Gateway Intents).
DISCORD_TOKEN=

# Clé de l'API Riot.
# https://developer.riotgames.com/ -> une clé de DÉVELOPPEMENT expire toutes les 24 h.
RIOT_API_KEY=

# Préfixe des commandes (optionnel, défaut « ! »).
COMMAND_PREFIX=!

# Plateforme par défaut (optionnel, défaut « euw1 » ; ex. na1, kr, eun1...).
DEFAULT_PLATFORM=euw1

# Génération des vannes du !classement par une IA (compatible OpenAI, optionnel).
# Sans clé, un générateur local prend le relais.
# Défaut = Groq (gratuit, sans carte bancaire) : créez une clé sur
# https://console.groq.com/keys puis collez-la ci-dessous.
LLM_API_KEY=
# URL et modèle (optionnels). Pour changer de fournisseur, adaptez ces deux valeurs :
#   Groq    : https://api.groq.com/openai/v1                         + llama-3.3-70b-versatile
#   Gemini  : https://generativelanguage.googleapis.com/v1beta/openai + gemini-2.0-flash
#   Mistral : https://api.mistral.ai/v1                              + mistral-small-latest
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Classement automatique (optionnel). Poste le !classement dans un salon aux heures voulues.
# Sans CLASSEMENT_CHANNEL_ID, la planification reste désactivée.
# ID du salon : activez le Mode Développeur (Discord -> Paramètres -> Avancés),
# puis clic droit sur le salon -> « Copier l'identifiant du salon ».
CLASSEMENT_CHANNEL_ID=
# Heures de publication « HH:MM » séparées par des virgules (défaut 10:00,20:00).
# Pour tester, mettez une heure proche (ex. « 14:45 ») puis remettez les vraies valeurs.
CLASSEMENT_HEURES=10:00,20:00
# Fuseau horaire des heures ci-dessus (défaut Europe/Paris).
CLASSEMENT_TZ=Europe/Paris

# Notification de fin de partie (optionnel). Poste les stats de la dernière partie CLASSÉE
# (Solo/Duo ou Flex) de chaque membre du roster dès qu'elle est terminée, avec une vanne et
# un GIF. Sans salon défini ici, on retombe sur CLASSEMENT_CHANNEL_ID ; sans aucun des deux,
# la surveillance reste désactivée.
MATCH_NOTIF_CHANNEL_ID=
# Intervalle de vérification des nouvelles parties, en minutes (défaut 5).
MATCH_POLL_MINUTES=5

# GIF de victoire/défaite via l'API Giphy (optionnel).
# Sans clé, un GIF d'une petite liste curée intégrée est utilisé (la notif a toujours un GIF).
# Avec une clé, les GIF sont variés par recherche. Clé beta gratuite et instantanée sur
# https://developers.giphy.com/dashboard/ (Create an App -> API Key).
GIPHY_API_KEY=
# Requêtes de recherche des GIF (optionnelles). Adaptez pour changer le style des GIF.
GIPHY_REQUETE_VICTOIRE="league of legends victory celebration"
GIPHY_REQUETE_DEFAITE="sad defeat fail"

# --- Tableau de bord des stats (app bureau, voir desktop/) --------------------
# Le bot journalise son activité dans un SQLite et l'expose via un petit serveur JSON
# que l'application bureau interroge. Tout est optionnel : les défauts conviennent en local.
# Mettre STATS_ENABLED=0 pour désactiver complètement la collecte et le serveur.
STATS_ENABLED=1
# Chemin de la base SQLite (relatif au dossier du projet). Créé automatiquement.
STATS_DB_PATH=data/stats.db
# Écoute du serveur JSON. 127.0.0.1 = local uniquement. Sur un VPS, passer à 0.0.0.0
# (de préférence derrière un reverse proxy) et pointer l'app via NEMESIS_STATS_URL.
STATS_API_HOST=127.0.0.1
STATS_API_PORT=8787
# Identifiant du bot dans le tableau de bord (préparé pour agréger plusieurs bots).
STATS_BOT_NAME=nemesis
